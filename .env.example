# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.

# ----------------------------------------------------------------------------
# Slack (optional)
# ----------------------------------------------------------------------------
SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ----------------------------------------------------------------------------
# Gemini — used by agent/explain.py (new google-genai SDK)
# ----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ----------------------------------------------------------------------------
# Email (SMTP) — used by agent/notify.py
# Set SMTP_HOST to enable email; leave blank to disable.
# ----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=                 # comma-separated default recipients
SMTP_USE_TLS=1

# ----------------------------------------------------------------------------
# Notification routing (severity = low|medium|high|critical)
# ----------------------------------------------------------------------------
ALERT_SLACK_MIN_SEVERITY=low
ALERT_EMAIL_MIN_SEVERITY=high
# Dedupe window: same (user, region, product) anomaly won't re-notify within this many seconds.
ALERT_COOLDOWN_SECONDS=1800

# ----------------------------------------------------------------------------
# OpenAI (only used by test.py — optional)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

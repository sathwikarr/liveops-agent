# Streamlit secrets — copy this file to `secrets.toml` and fill in real values.
# `secrets.toml` is git-ignored. Never commit real secrets.
#
# Streamlit reads these via `st.secrets["KEY"]`. The same keys can also be
# provided via environment variables / .env — both work.

SLACK_WEBHOOK = ""
GEMINI_API_KEY = ""
GEMINI_MODEL = "gemini-2.5-flash"

# Optional — only used by test.py
OPENAI_API_KEY = ""
OPENAI_BASE_URL = "https://api.openai.com/v1"

# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.

# ============================================================================
# CORE — required for production. Generate fresh values per environment.
# ============================================================================

# Signs the session cookie. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Encrypts saved Slack webhooks + SMTP creds at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key invalidates existing encrypted connectors.
LIVEOPS_FERNET_KEY=

# ============================================================================
# Storage paths (all optional; defaults work for local dev)
# ============================================================================
# LIVEOPS_DB=data/liveops.sqlite3
# LIVEOPS_UPLOAD_DIR=user_data/workbench_uploads

# ============================================================================
# Gemini — LLM planner backend. Without it, the heuristic planner runs.
# ============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Set to 1 to log [llm-fallback] reasons to stderr (network errors, parse
# failures, etc.). Useful when "I picked LLM but plan.backend says heuristic".
# LIVEOPS_LLM_DEBUG=0

# ============================================================================
# Notification channels — server-default fallbacks if a user hasn't set their
# own connector via /settings. Per-user encrypted creds always win.
# ============================================================================
SLACK_WEBHOOK=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=1

# Severity routing for the ops loop's anomaly notifications.
ALERT_SLACK_MIN_SEVERITY=low
ALERT_EMAIL_MIN_SEVERITY=high
ALERT_COOLDOWN_SECONDS=1800
